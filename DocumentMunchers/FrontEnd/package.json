{
  "name": "damb-document-munchers",
  "version": "0.1.0",
  "description": "Electron + React + TypeScript app (Vite)",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "tsc": "tsc --noEmit",
    "build:ui": "vite build",
    "build": "npm run build:ui && electron-builder",
    "start": "electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "jquery": "^3.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^7.6.0",
    "electron": "^39.2.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.2.2",
    "wait-on": "^7.2.0"
  },
  "allowScripts": {
    "electron@39.8.10": true,
    "esbuild@0.27.7": true
  }
}
